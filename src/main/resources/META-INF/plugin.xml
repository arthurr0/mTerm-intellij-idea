<idea-plugin>
    <id>dev.mterm</id>
    <vendor email="koeckiartur@gmail.com">Artur Kołecki</vendor>

    <description><![CDATA[
        <b>mTerm</b> opens terminal sessions as first-class editor tabs instead of tool-window panels.
        Launch Claude Code, Codex, or a system terminal in its own tab, or open the
        <b>mTerm</b> grid to run several agents side by side, resize and rearrange them,
        and get a sound when an agent finishes.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <extensions defaultExtensionNs="com.intellij">
        <virtualFileSystem key="mterm"
                           implementationClass="dev.mterm.vfs.MTermFileSystem"
                           physical="false"/>
        <fileEditorProvider implementation="dev.mterm.session.MTermSessionEditorProvider"/>
        <fileEditorProvider implementation="dev.mterm.grid.MTermGridEditorProvider"/>
        <applicationService serviceImplementation="dev.mterm.settings.MTermSettings"/>
        <applicationConfigurable parentId="tools"
                                 id="dev.mterm.settings"
                                 displayName="mTerm"
                                 instance="dev.mterm.settings.MTermConfigurable"/>
    </extensions>

    <projectListeners>
        <listener class="dev.mterm.vfs.MTermFileCloseListener"
                  topic="com.intellij.openapi.fileEditor.FileEditorManagerListener"/>
    </projectListeners>

    <actions>
        <group id="mTerm.NewTabGroup" text="mTerm" popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>

            <action id="mTerm.OpenGrid"
                    class="dev.mterm.actions.OpenMTermGridAction"
                    icon="/icons/mterm.svg"
                    text="Open mTerm Grid"
                    description="Open the mTerm multi-agent terminal grid in an editor tab">
                <add-to-group group-id="MainToolbarRight" anchor="first"/>
            </action>
            <separator/>
            <action id="mTerm.NewClaudeCode"
                    class="dev.mterm.actions.OpenClaudeCodeTabAction"
                    text="New Claude Code Tab"
                    description="Open a Claude Code terminal session as an editor tab"/>
            <action id="mTerm.NewCodex"
                    class="dev.mterm.actions.OpenCodexTabAction"
                    text="New Codex Tab"
                    description="Open a Codex terminal session as an editor tab"/>
            <action id="mTerm.NewSystemTerminal"
                    class="dev.mterm.actions.OpenSystemTerminalTabAction"
                    text="New System Terminal Tab"
                    description="Open a system terminal session as an editor tab"/>
        </group>
    </actions>
</idea-plugin>
